{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently \"php artisan serve\" \"npm run dev:frontend\"",
        "dev:frontend": "cd frontend && npm run dev",
        "build": "cd frontend && npm run build",
        "build:backend": "composer install --no-dev --optimize-autoloader",
        "deploy": "npm run build:backend && npm run build",
        "migrate": "php artisan migrate",
        "seed": "php artisan db:seed"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.1",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.2.1",
        "vite": "^7.3.1"
    },
    "dependencies": {
        "html5-qrcode": "^2.3.8",
        "next": "^16.1.6",
        "qrcode.react": "^4.2.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    }
}
